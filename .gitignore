# ─── .gitignore ────────────────────────────────
node_modules/
dist/
.next/
.turbo/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# Credentials
service-account.json
*.pem

# OS
.DS_Store
Thumbs.db

# Terraform
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/.terraform.lock.hcl
infra/terraform/envs/*.secrets.tfvars
!infra/terraform/envs/*.secrets.tfvars.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
npm-debug.log*
*.log
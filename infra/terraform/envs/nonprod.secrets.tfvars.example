# Copy to nonprod.secrets.tfvars (gitignored) and set the value.
# If this token was ever committed to git, rotate it in @BotFather.
telegram_bot_token_secret = ""

# Same string you pass as secret_token to Telegram setWebhook (see apps/api/src/routes/telegram.ts).
telegram_webhook_secret = ""

# Random string; send as X-Vector-Job-Secret (or Authorization: Bearer) to POST /generate-daily and /send-reminders.
internal_job_secret = ""

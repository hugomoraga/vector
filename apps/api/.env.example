# Copy to .env and/or .env.local (both are loaded from apps/api cwd; .env.local overrides .env)
# Loaded via src/load-env.ts before Firebase Admin initializes (import order matters).
#
# Firebase Admin (required for local dev so tokens match NEXT_PUBLIC_FIREBASE_* on the web)
# Service account: Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# PEM newlines in .env must be escaped as \n (single line)
FIREBASE_PRIVATE_KEY=

# Internal cron jobs (POST /generate-daily, /send-reminders). Required in production (NODE_ENV=production).
# Cloud Scheduler: header X-Vector-Job-Secret or Authorization: Bearer <value>
INTERNAL_JOB_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
# Bot @handle without "@" — used for t.me deep links from Settings
TELEGRAM_BOT_USERNAME=
# Same value you pass as secret_token to setWebhook; required in production
TELEGRAM_WEBHOOK_SECRET=

# Optional bot copy (webhook /start). Multiline: use \n in the value. Plain welcome may include {{chatId}}.
# TELEGRAM_MSG_WELCOME_PLAIN=
# TELEGRAM_MSG_WELCOME_LINKED=
# TELEGRAM_MSG_LINK_INVALID=

# Optional: JSON merged over apps/api/src/config/reminder-template.default.json (reminder /send-reminders layout).
# TELEGRAM_REMINDER_TEMPLATE_JSON={"header":"..."}

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
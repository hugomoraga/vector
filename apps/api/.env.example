# Copy to .env and/or .env.local (both are loaded from apps/api cwd; .env.local overrides .env)
# Loaded via src/load-env.ts before Firebase Admin initializes (import order matters).
#
# Firebase Admin (required for local dev so tokens match NEXT_PUBLIC_FIREBASE_* on the web)
# Service account: Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# PEM newlines in .env must be escaped as \n (single line)
FIREBASE_PRIVATE_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
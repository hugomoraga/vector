{
  "name": "vector",
  "version": "0.1.9",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "validate": "turbo run lint typecheck",
    "docker:api": "docker build -f apps/api/Dockerfile -t vector-api:local .",
    "docker:web": "bash scripts/docker-web-build.sh",
    "docker:web:smoke": "bash scripts/docker-web-smoke.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "eslint": "^8.57.0"
  }
}
